{
  "manifest_version": 3,
  "name": "Quick Fill",
  "version": "1.2.0",
  "description": "See all form fields on a page and fill them instantly.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "fill-all": { "suggested_key": { "default": "Ctrl+Shift+F" }, "description": "Fill all fields on the page" },
    "fill-submit": { "suggested_key": { "default": "Ctrl+Shift+S" }, "description": "Fill all fields and submit" }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["storage", "activeTab", "scripting", "alarms", "contextMenus"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
